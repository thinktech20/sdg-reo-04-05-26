# ==============================================================================
# sdg-qna-agent — Strands SDK + FastAPI
# Build context: backend/ (uv workspace root)
# Port: 8005
# ==============================================================================
FROM python:3.13-slim

# Install uv
RUN python -m pip install --no-cache-dir uv

WORKDIR /app

# Copy workspace root (pyproject + lock) and this agent
COPY pyproject.toml uv.toml .python-version uv.lock ./
COPY libs/ ./libs/
COPY certs/ ./certs/
COPY agents/question-answer-agent/ ./agents/question-answer-agent/

# Install only this agent's deps (no dev group, frozen lock)
RUN uv sync --frozen --no-dev --package sdg-qna-agent \
     && VIRTUAL_ENV=/app/.venv uv pip install --no-cache "litellm>=1.67.0"

# Build a merged CA bundle: certifi's trusted roots + any extra certs in
# backend/certs/ (e.g. GE/corporate root CAs). Missing local cert files should
# not break CI builds.
RUN /app/.venv/bin/python -c 'import certifi,shutil; shutil.copy(certifi.where(), "/app/certs/ge-ca-bundle.pem")' \
    && cat /app/certs/*.crt >> /app/certs/ge-ca-bundle.pem 2>/dev/null; \
    cat /app/certs/*.pem >> /app/certs/ge-ca-bundle.pem 2>/dev/null; \
    echo "CA bundle ready: $(wc -c < /app/certs/ge-ca-bundle.pem) bytes"

# Tell Python and requests-based clients to use the merged bundle.
ENV SSL_CERT_FILE=/app/certs/ge-ca-bundle.pem
ENV REQUESTS_CA_BUNDLE=/app/certs/ge-ca-bundle.pem

# Non-root user
RUN useradd --create-home --home-dir /home/appuser --shell /bin/false appuser \
     && mkdir -p /home/appuser/.cache/uv \
     && chown -R appuser:appuser /home/appuser
ENV HOME=/home/appuser
ENV UV_CACHE_DIR=/home/appuser/.cache/uv
ENV PATH="/app/.venv/bin:${PATH}"
USER appuser

EXPOSE 8087

CMD ["uvicorn", "question_answer.main:app", \
     "--host", "0.0.0.0", "--port", "8087", "--workers", "1"]

