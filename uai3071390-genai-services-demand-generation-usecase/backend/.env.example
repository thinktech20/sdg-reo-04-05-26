# =============================================================================
# SDG Risk Analyser — Environment Variables
# Copy this file to .env and fill in values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# LiteLLM Proxy (platform-provided)
# -----------------------------------------------------------------------------
LITELLM_API_KEY=your-litellm-api-key
LITELLM_API_PROXY_KEY=your-litellm-api-key
LITELLM_PROXY_URL=https://dev-gateway.apps.gevernova.net
LITELLM_MODEL=litellm_proxy/azure-gpt-5-2
# Optional compatibility aliases (A1 also accepts these names)
# LITELLM_API_BASE=https://dev-gateway.apps.gevernova.net
# LITELLM_MODEL_ID=litellm_proxy/azure-gpt-5-2
LITELLM_MODEL_ID= 'azure-gpt-5-2'
LITELLM_API_BASE="https://dev-gateway.apps.gevernova.net/"
LITELLM_PROXY_API_KEY=<Token>
 
MCP_SERVER_PARAMS=http://localhost:8086/dataservices/mcp/

# -----------------------------------------------------------------------------
# NakshaClient — Databricks SQL via Naksha Agent API proxy
# Used by data-service. Safe to leave blank when USE_MOCK=true.
# -----------------------------------------------------------------------------
NAKSHA_API_URL=https://lp3c4ukmlh.execute-api.us-east-1.amazonaws.com/Dev/databricks-orchestrator-proxy-dev
NAKSHA_BUSINESS=gas_power
NAKSHA_DOMAIN=global_services
NAKSHA_SUBDOMAIN=fsr
NAKSHA_USER_DOMAINS=fsr,prm,seg,qlt
NAKSHA_USER_GROUP_IDS=
NAKSHA_USER_EMAIL=test@ge.com
USE_MOCK=false     # Set to false to hit real Naksha endpoint
GE_ENTERPRISE_CA_CERT=/app/certs/GE_Enterprise_Root_CA_2_1.pem
GE_EXTERNAL_CA_CERT=/app/certs/GE_External_Root_CA_2_1.crt
SSL_CERT_FILE=/app/certs/ge-ca-bundle.pem
REQUESTS_CA_BUNDLE=/app/certs/ge-ca-bundle.pem

# -----------------------------------------------------------------------------
# Session Storage — S3 / MinIO
# For local dev, MinIO runs in Docker Compose (see compose.yml)
# -----------------------------------------------------------------------------
SESSION_S3_BUCKET_NAME=app-uai3071390-sdg-dev-s3-qna-session
S3_LOCAL_MODE=true    # Set to false in AWS; true uses S3_ENDPOINT_URL (MinIO)
S3_ENDPOINT_URL=http://localhost:9000   # MinIO local endpoint (local only)
AWS_ACCESS_KEY_ID=minioadmin            # MinIO local creds (local only)
AWS_SECRET_ACCESS_KEY=minioadmin        # MinIO local creds (local only)
AWS_DEFAULT_REGION=us-east-1

# -----------------------------------------------------------------------------
# DynamoDB
# For local dev, dynamodb-local runs in Docker Compose on port 8000.
# Set DYNAMODB_ENDPOINT_URL to point boto3 at the local emulator.
# In AWS, remove or leave DYNAMODB_ENDPOINT_URL unset to use the real service.
# -----------------------------------------------------------------------------
DYNAMODB_ENDPOINT_URL=http://localhost:8000   # local only — remove in AWS
DYNAMODB_REGION=us-east-1
RISK_ANALYSIS_TABLE=app-uai3071390-sdg-ddtable-risk-analysys-output-table-dev
NARRATIVE_SUMMARY_TABLE=app-uai3071390-sdg-ddtable-navigation-summary-dev
EVENT_HISTORY_TABLE=app-uai3071390-sdg-ddtable-event-history-report-dev
EXECUTION_STATE_TABLE=app-uai3071390-sdg-ddtable-execution-state-store-dev
LANGGRAPH_CHECKPOINTER_TABLE=app-uai3071390-sdg-ddtable-orchestrator-checkpointer-dev
ORCHESTRATOR_CHECKPOINTER_TYPE=dynamodb
# Orchestrator job state shares the execution-state table (same schema, no separate table needed).
ORCHESTRATOR_USE_DYNAMODB=true

# -----------------------------------------------------------------------------
# Agent → Data Service URL
# For local dev, data-service runs in Docker Compose
# -----------------------------------------------------------------------------
DATA_SERVICE_URL=http://localhost:8086   # sdg-data-service base URL (no path suffix)

# -----------------------------------------------------------------------------
# Authentication
# AUTH_LOCAL_MODE=true skips JWT validation (local dev only)
# In AWS: PingID OIDC at the ALB handles authentication.
# After ALB validation, user identity is injected via ALB OIDC headers:
#   X-Amzn-OIDC-Identity  — user sub claim
#   X-Amzn-OIDC-Data      — ALB-signed JWT (ES256)
# RBAC (roles/permissions) is handled by Foundation Services via OneIDM adapter
# — our containers do NOT call OneIDM/MAP directly.
# -----------------------------------------------------------------------------
AUTH_LOCAL_MODE=true
# EXPECTED_ALB_ARN=arn:aws:elasticloadbalancing:us-east-1:123456789:loadbalancer/app/sdg-alb/xxx  # Required in AWS
# ALB_REGION=us-east-1                                                                             # Required in AWS

# -----------------------------------------------------------------------------
# Langfuse Observability (platform-provided)
# -----------------------------------------------------------------------------
LANGFUSE_HOST=https://your-langfuse.internal
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key

# -----------------------------------------------------------------------------
# Per-service identity (used in health/logging — change per deployment)
# Agents A1–A3 (risk-eval, narrative, event-history) use LiteLLM.
# Only the Q&A agent uses the full Strands SDK with session management.
# -----------------------------------------------------------------------------
AGENT_NAME=sdg-risk-eval-assistant   # Change per agent deployment


# Proxy
HTTP_PROXY=http://PITC-Zscaler-Global-3PRZ.proxy.corporate.ge.com:80
HTTPS_PROXY=http://PITC-Zscaler-Global-3PRZ.proxy.corporate.ge.com:80
NO_PROXY=localhost,127.0.0.1,.corp,dev-gateway.apps.gevernova.net,.cloud.databricks.com

LOG_SQL_QUERIES=true

CATALOG=vgpd

#IBAT
IBAT_SCHEMA=prm_std_views
IBAT_EQUIPMENT_TABLE=IBAT_EQUIPMENT_MST
IBAT_PLANT_TABLE=IBAT_PLANT_MST
IBAT_TRAIN_TABLE=IBAT_TRAIN_MST

##Databricks

DATABRICKS_HOST=https://gevernova-nrc-workspace.cloud.databricks.com
DATABRICKS_TOKEN=<Token>
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/daff57b69fee5745

##App Prefix
APP_PREFIX=uai3071390-dev-sdg
LANGGRAPH_CHECKPOINTER_TABLE=app-uai3071390-sdg-ddtable-orchestrator-checkpointer-dev
EXECUTION_STATE_TABLE=app-uai3071390-sdg-ddtable-execution-state-store-dev

IBAT_MAX_RETRIES=3
IBAT_RETRY_BACKOFF_SECONDS=1.5

# ER Cases (Engineering Reviews)
# LOCAL CONFIG USES VGPD CATALOG FOR ER CASES, BUT IN AWS IT SHOULD BE VGPP (POINT TO PRODUCTION DATA)
ER_CATALOG=vgpd
ER_SCHEMA=qlt_std_views
ER_TABLE=u_pac

# FSR Reports (Field Service Reports)
FSR_CATALOG=vgpd
FSR_SCHEMA=fsr_std_views
FSR_TABLE=fsr_field_vision_field_services_report_psot

# Outage History / Event Master
EVENT_MASTER_CATALOG=vgpd
EVENT_MASTER_SCHEMA=fsr_std_views
OUTAGE_EVENTMGMT_TABLE=eventmgmt_event_vision_sot
OUTAGE_EQUIP_DTLS_TABLE=event_equipment_dtls_event_vision_sot
OUTAGE_SCOPE_TABLE=scope_schedule_summary_event_vision_sot

# PRISM (Reliability Models)
PRISM_SCHEMA=seg_std_views
PRISM_SOT_TABLE=seg_fmea_wo_models_gen_psot
PRISM_MAX_RETRIES=3
PRISM_RETRY_BACKOFF_SECONDS=1.5

# Heatmap
HEATMAP_SCHEMA=fsr_std_views
HEATMAP_TABLE=fsr_unit_risk_matrix_view
HEATMAP_MAX_RETRIES=3
HEATMAP_RETRY_BACKOFF_SECONDS=1.5

# Train Service
TRAIN_QUERY_LIMIT=5
TRAIN_MAX_RETRIES=3
TRAIN_RETRY_BACKOFF_SECONDS=1.5
