# =============================================================================
# SDG Risk Analyser — Environment Variables
# Copy this file to .env and fill in values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# LiteLLM Proxy (platform-provided)
# -----------------------------------------------------------------------------
LITELLM_MODEL_ID= 'azure-gpt-5-2'
LITELLM_API_BASE="https://dev-gateway.apps.gevernova.net/"
LITELLM_PROXY_API_KEY=<Token>

LITELLM_API_KEY=your-litellm-api-key
LITELLM_API_BASE=https://your-litellm-proxy.internal   # Used by all agents as LITELLM_API_BASE
LITELLM_MODEL=gpt-4o
 
MCP_SERVER_PARAMS=http://localhost:8086/mcp

# -----------------------------------------------------------------------------
# NakshaClient — Databricks SQL via Naksha Agent API proxy
# Used by data-service. Safe to leave blank when USE_MOCK=true.
# -----------------------------------------------------------------------------
NAKSHA_API_URL=https://qpbq9edtta.execute-api.us-east-1.amazonaws.com/QA/databricks-proxy-chatbot-dev
NAKSHA_BUSINESS=gas_power
NAKSHA_DOMAIN=global_services
NAKSHA_SUBDOMAIN=fsr
NAKSHA_TIMEOUT=120
NAKSHA_MAX_RETRIES=3
NAKSHA_VERIFY_SSL=true
NAKSHA_USER_DOMAINS=fsr
NAKSHA_USER_GROUP_IDS=
NAKSHA_USER_EMAIL=your-email@example.com
NAKSHA_POLL_INTERVAL_SECONDS=2
NAKSHA_MAX_POLLS=60
USE_MOCK=false     # Set to true to use mock responses instead of the real Naksha endpoint
GE_ENTERPRISE_CA_CERT=/app/certs/GE_Enterprise_Root_CA_2_1.pem
GE_EXTERNAL_CA_CERT=/app/certs/GE_External_Root_CA_2_1.crt
SSL_CERT_FILE=/app/certs/ca.crt
REQUESTS_CA_BUNDLE=/app/certs/ca.crt

# -----------------------------------------------------------------------------
# Session Storage — S3 / MinIO
# For local dev, MinIO runs in Docker Compose (see compose.yml)
# -----------------------------------------------------------------------------
SESSION_S3_BUCKET_NAME=sdg-agent-sessions
S3_LOCAL_MODE=true    # Set to false in AWS; true uses S3_ENDPOINT_URL (MinIO)
S3_ENDPOINT_URL=http://localhost:9000   # MinIO local endpoint (local only)
AWS_ACCESS_KEY_ID=minioadmin            # MinIO local creds (local only)
AWS_SECRET_ACCESS_KEY=minioadmin        # MinIO local creds (local only)
AWS_DEFAULT_REGION=us-east-1

# -----------------------------------------------------------------------------
# Agent → Data Service URL
# For local dev, data-service runs in Docker Compose
# -----------------------------------------------------------------------------
DATA_SERVICE_URL=http://localhost:8086   # sdg-data-service base URL (no path suffix)

# -----------------------------------------------------------------------------
# Authentication
# AUTH_LOCAL_MODE=true skips JWT validation (local dev only)
# In AWS: PingID OIDC at the ALB handles authentication.
# After ALB validation, user identity is injected via ALB OIDC headers:
#   X-Amzn-OIDC-Identity  — user sub claim
#   X-Amzn-OIDC-Data      — ALB-signed JWT (ES256)
# RBAC (roles/permissions) is handled by Foundation Services via OneIDM adapter
# — our containers do NOT call OneIDM/MAP directly.
# -----------------------------------------------------------------------------
AUTH_LOCAL_MODE=true
# EXPECTED_ALB_ARN=arn:aws:elasticloadbalancing:us-east-1:123456789:loadbalancer/app/sdg-alb/xxx  # Required in AWS
# ALB_REGION=us-east-1                                                                             # Required in AWS

# -----------------------------------------------------------------------------
# Langfuse Observability (platform-provided)
# -----------------------------------------------------------------------------
LANGFUSE_HOST=https://your-langfuse.internal
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key

# -----------------------------------------------------------------------------
# Per-service identity (used in health/logging — change per deployment)
# Agents A1–A3 (risk-eval, narrative, event-history) use LiteLLM.
# Only the Q&A agent uses the full Strands SDK with session management.
# -----------------------------------------------------------------------------
AGENT_NAME=sdg-risk-eval-assistant   # Change per agent deployment


# Proxy
HTTP_PROXY=http://your-corporate-proxy:80
HTTPS_PROXY=http://your-corporate-proxy:80
NO_PROXY=localhost,127.0.0.1,.corp,https://dev-gateway.apps.gevernova.net,.cloud.databricks.com

LOG_SQL_QUERIES=true

CATALOG=vgpd

# IBAT
IBAT_SCHEMA=prm_std_views
IBAT_EQUIPMENT_TABLE=IBAT_EQUIPMENT_MST
IBAT_PLANT_TABLE=IBAT_PLANT_MST
IBAT_TRAIN_TABLE=ibat_train_mst


## Databricks

# -----------------------------------------------------------------------------
# Frontend (Vite dev server only — not used in production Docker build)
# In production, nginx proxies /api/* to orchestrator:8006 via nginx.conf.
# Override this when running pnpm dev outside Docker Compose.
# -----------------------------------------------------------------------------
VITE_API_TARGET=http://localhost:8086   # Vite dev server /api proxy target

# Direct-to-service URLs baked into the Vite bundle at build time.
# When set the browser bypasses nginx and calls each service directly.
# Leave blank (default) to use nginx proxy pass (production behaviour).
VITE_DATA_SERVICE_URL=http://localhost:8086   # data-service (port 8086)
VITE_QNA_AGENT_URL=http://localhost:8085      # qna-agent WebSocket chat (port 8085)

##App Prefix
APP_PREFIX=uai3071390-dev-sdg
LANGGRAPH_CHECKPOINTER_TABLE=app-uai3071390-sdg-ddtable-orchestrator-checkpointer-dev
EXECUTION_STATE_TABLE=app-uai3071390-sdg-ddtable-execution-state-store-dev

