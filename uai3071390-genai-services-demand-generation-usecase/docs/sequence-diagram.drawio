                <mxCell id="a7" value="risk findings / categories" style="endArrow=open;endFill=0;dashed=1;dashPattern=8 8;strokeColor=#b85450;fontColor=#b85450;fontSize=10;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
