                </mxCell>
                <mxCell id="a3" value="HTTP 202 Accepted  { assessmentId, workflowId, workflowStatus: PENDING }" style="endArrow=open;endFill=0;dashed=1;dashPattern=8 8;strokeColor=#0050AA;fontColor=#0050AA;fontSize=10;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="255" y="932" as="sourcePoint"/>
                        <mxPoint x="85" y="932" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="a4" value="[background FastAPI task]  POST /orchestrator/api/v1/assessments/{id}/run  { assessment_id, job_type: &quot;run&quot;, esn, persona,  input_payload: { persona, equipmentType, serialNumber,  dataTypes: assessment.filters.dataTypes,  dateFrom: assessment.filters.fromDate,  dateTo: assessment.filters.toDate } }" style="endArrow=open;endFill=1;strokeColor=#006600;fontColor=#006600;fontSize=10;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="255" y="964" as="sourcePoint"/>
                        <mxPoint x="440" y="964" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="a4b" value="orchestrator: job_store.write_job(PENDING) → _run_pipeline as background task → writes RUNNING. Agent calls via _call_agent(): timeout=360s, max_retries=3, backoff=attempt×5s (5s/10s/15s), retries on TimeoutException | NetworkError | HTTP 5xx — 4xx not retried. During pipeline: PATCH /internal/assessments/{id}/execution-state [fire-and-forget, circuit-breaker, up to 3 retries]. RE→finalize_node; OE→event_history_node→finalize_node" style="endArrow=none;dashed=1;dashPattern=4 4;strokeColor=#888;fontColor=#888;fontSize=9;align=left;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="440" y="990" as="sourcePoint"/>
                        <mxPoint x="840" y="990" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="a5" value="POST /riskevaluationassistant/api/v1/risk-eval/run  { assessment_id, esn, serial_number, component_type, persona,  filters: { data_types, date_from, date_to } }  (orchestrator normalises camelCase→snake_case)  [_call_agent: timeout=360s, max_retries=3, backoff=attempt×5s; retries on TimeoutException | NetworkError | HTTP 5xx — 4xx not retried]" style="endArrow=open;endFill=1;strokeColor=#006600;fontColor=#006600;fontSize=10;" parent="1" source="p3" target="p4" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="440" y="1016" as="sourcePoint"/>
                        <mxPoint x="620" y="1016" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
