                        <mxPoint x="440" y="1100" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="a9" value="LangGraph checkpoint after risk_eval_node (thread_id={assessment_id}:run:{persona}) → orchestrator-checkpointer. Data-service polls: GET /orchestrator/api/v1/assessments/{id}/status?jobType=run. Poll ceiling: 200 × 3s = 600s (ORCHESTRATOR_POLL_MAX_ATTEMPTS env var, was 60 × 3s = 180s). RE path: risk_eval_node → finalize_node; OE path runs event_history_node (:8084) first." style="endArrow=open;endFill=1;dashed=1;dashPattern=4 4;strokeColor=#b85450;fontColor=#b85450;fontSize=10;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
