                <mxCell id="a8" value="HTTP 200  { data, findings, riskCategories, status: completed }" style="endArrow=open;endFill=0;dashed=1;dashPattern=8 8;strokeColor=#006600;fontColor=#006600;fontSize=10;" parent="1" edge="1">
