                        <mxPoint x="1315" y="1128" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="a10b" value="AGENT_SIMULATE_MODE=true: risk-eval skips LLM; POSTs sample to data-service POST /internal/assessments/{id}/risk-eval-sample (TODO: replace with production persistence)" style="endArrow=none;dashed=1;dashPattern=4 4;strokeColor=#888;fontColor=#888;fontSize=9;align=left;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
